---
const { currentLink } = Astro.props;
---

<style>
    nav {
        border-block: 3px solid white;
        padding: 1em;
    }
    ul {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        padding: 0;
    }

    .currentLink {
        background-color: grey;
    }
</style>

<nav>
    <ul>
        <li>
            <a
                href="/hbthings/paintings"
                class:list={[{ currentLink: currentLink === "paintings" }]}
                >Paintings</a
            >
        </li>
        <li>
            <a
                class:list={[{ currentLink: currentLink === "photography" }]}
                href="/hbthings/photography">Photography</a>
        </li>
        <li>
            <a
                class:list={[{ currentLink: currentLink === "video" }]}
                href="/hbthings/video">Video</a>
        </li>
        <li>
            <a
                class:list={[{ currentLink: currentLink === "projects" }]}
                href="/hbthings/projects">Projects</a>
        </li>
        <li>
            <a
                class:list={[{ currentLink: currentLink === "poetry" }]}
                href="/hbthings/poetry">Poetry</a>
        </li>
    </ul>
</nav>
